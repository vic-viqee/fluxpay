# --- Backend Configuration ---
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/fluxpay

# CORS Configuration - comma-separated list of allowed origins
# Default includes localhost:5173 and localhost:3000
# Add production domains here, e.g.: https://fluxpay-frontend.onrender.com,https://your-domain.com
ALLOWED_ORIGINS=

# --- Cloudinary Configuration (Optional - for durable file storage) ---
# Get these from https://cloudinary.com/console
# When configured, uploaded files will be stored in Cloudinary instead of local disk
# This is recommended for production deployments (Render, etc.)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key
JWT_REFRESH_SECRET=your_super_secret_refresh_key
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# URLs
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# --- Google OAuth Configuration ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# --- Email Service Configuration ---
# For Brevo (Production):
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USER=your_brevo_email@example.com
# EMAIL_PASS=your_brevo_smtp_key

# For Local Testing (Mailhog - if available):
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=no-reply@fluxpay.com

# --- M-Pesa Configuration ---
CONSUMER_KEY=
CONSUMER_SECRET=
SHORTCODE=
PASSKEY=
CALLBACK_URL=http://your-public-ip-or-domain/api/payments/callback

# --- Frontend Configuration ---
# This is usually used in the frontend .env but kept here for reference
VITE_API_URL=http://localhost:3000/api
