# FluxPay Environment Variables

# Database
DATABASE_URL=postgresql://fluxpay:fluxpay123@localhost:5432/fluxpay

# Redis
REDIS_URL=redis://localhost:6379

# LocalStack (S3 mock)
LOCALSTACK_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_REGION=us-east-1
AWS_S3_ENDPOINT=$${LOCALSTACK_URL}

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# M-Pesa (Sandbox)
M_PESA_CONSUMER_KEY=your-consumer-key
M_PESA_CONSUMER_SECRET=your-consumer-secret
M_PESA_SHORTCODE=174379
M_PESA_PASSKEY=your-passkey
M_PESA_CALLBACK_URL=http://localhost:3001/payments/callback

# Frontend API
NEXT_PUBLIC_API_URL=http://localhost:3001

# NextAuth (Frontend)
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000
